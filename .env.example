# Wallet (required for live trading)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_ADDRESS=

# Optional overrides
# 网络代理（也可在 Dashboard「设置 → 网络」配置）
# 固定 IP 代理（本地 Clash/V2Ray 等）:
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# 或在 config.yaml 的 global.proxy 中设置 mode: static / dynamic
# POLYMARKET_SIGNATURE_TYPE=1
# POLYMARKET_CHAIN_ID=137
# POLYMARKET_CLOB_URL=https://clob.polymarket.com
# POLYMARKET_DATA_API_URL=https://data-api.polymarket.com

# Optional CLOB API credentials (otherwise auto-derive via SecureClient)
# Deposit wallet (SIGNATURE_TYPE=3): create keys in Polymarket Settings → Developer while logged in.
# Auto-derive binds to EOA and cannot post POLY_1271 orders (Polymarket/clob-client-v2#65).
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=

# Optional Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_ON_COPY=true
# TELEGRAM_ON_ERROR=true
# TELEGRAM_ON_KILL_SWITCH=true

# Health check HTTP server (GET /health) + Dashboard UI
# HEALTH_PORT=8080
# HEALTH_BIND=127.0.0.1
# Docker Compose sets HEALTH_BIND=0.0.0.0 so port mapping works.

# Dashboard API auth (required when HEALTH_BIND is not 127.0.0.1, e.g. Docker)
# DASHBOARD_TOKEN=your-random-secret-here
# DASHBOARD_ENABLED=true

# Override SQLite path (default: data/preview.db or data/polymirror.db)
# POLYMIRROR_DB_PATH=data/custom.db

# Live trading safety gate (required when preview_mode: false)
# REQUIRE_LIVE_CONFIRM=true
# POLYMIRROR_LIVE_CONFIRM=I_UNDERSTAND_LIVE_TRADING

# Live trading uses @polymarket/client SecureClient (POLYMARKET_TRADING_BACKEND is always secure)
# RELAYER_API_KEY=
# RELAYER_API_KEY_ADDRESS=
# Must match the address shown next to the key in Polymarket Settings → Developer (Relayer API)
# settings = use POLYMARKET_ADDRESS (default when it differs from EOA); auto = SDK-derived wallet
# POLYMARKET_SECURE_WALLET=settings
