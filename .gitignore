# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
dashboard/node_modules/
.pnp/
.pnp.js
.yarn/cache/
.yarn/unplugged/

# ---------------------------------------------------------------------------
# Build output
# ---------------------------------------------------------------------------
dist/
build/
out/
dashboard/dist/

# TypeScript incremental build info
*.tsbuildinfo
tsconfig.tsbuildinfo
dashboard/tsconfig.tsbuildinfo

# ---------------------------------------------------------------------------
# Environment & local configuration (may contain secrets / private keys)
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.env.bak
config.yaml
config.yaml.bak
config.local.yaml
*.local.yaml

# ---------------------------------------------------------------------------
# Runtime data (SQLite databases, keep the data/ directory itself)
# ---------------------------------------------------------------------------
data/**
!data/.gitkeep

# Wallet / key exports (never commit)
*.pem
*.key

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# Caches & test coverage
# ---------------------------------------------------------------------------
.cache/
.vite/
.vitest/
coverage/
*.lcov
.eslintcache

# ---------------------------------------------------------------------------
# Editor / IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# OS-generated files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Temporary files
# ---------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.pid
