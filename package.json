{
  "name": "polymirror",
  "version": "1.0.0",
  "description": "Multi-leader copy trading on Polymarket",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "polymirror": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && npm run build:dashboard",
    "build:dashboard": "npm run build --prefix dashboard",
    "build:daemon": "tsc",
    "start": "npm run build:daemon && node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:dashboard": "npm run dev --prefix dashboard",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "tsx scripts/patch-polymarket-client.mts",
    "audit": "npm audit --audit-level=critical",
    "docker:build": "docker build -t polymirror:1.0.0 .",
    "place-order": "tsx scripts/place-order.mts"
  },
  "keywords": [
    "polymarket",
    "copy-trading",
    "prediction-markets"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ethersproject/wallet": "^5.7.0",
    "@polymarket/client": "^0.1.0-beta.7",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.0",
    "ethers": "^5.8.0",
    "ethers-v5": "npm:ethers@^5.8.0",
    "undici": "^6.27.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  }
}
